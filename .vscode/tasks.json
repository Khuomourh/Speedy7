{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Speedy7 App",
      "type": "shell",
      "command": "node",
      "args": ["server.js"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "speedy7",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Speedy7 is running",
          "endsPattern": "Speedy7 is running"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Check Speedy7 Code",
      "type": "shell",
      "command": "npm.cmd",
      "args": ["run", "check"],
      "group": "test",
      "problemMatcher": []
    }
  ]
}
